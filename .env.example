# Hosted open-source LLM provider. Do not commit real keys.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional Hugging Face hosted inference.
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Managed vector database. Use Qdrant Cloud, not local Qdrant, if you want no local compute.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=personal_work_agent_memory

# Optional live web research providers. Tavily is best for agent research.
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Safety defaults.
REQUIRE_APPROVAL_FOR_EXTERNAL_ACTIONS=true
MAX_AGENT_STEPS=8
